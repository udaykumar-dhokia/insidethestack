// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  AI
  DEVELOPER_TOOLS
  CLOUD
  PRODUCTIVITY
  DEVOPS_INFRASTRUCTURE
  AUTOMATION
  COMMUNICATION
}

model User {
  id              String     @id @default(uuid())
  first_name      String
  last_name       String?
  username        String     @unique
  email           String     @unique
  password        String
  social          Social?
  posts           Posts[]
  comments        Comments[]
  isEmailVerified Boolean    @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  likes      Likes[]
}

model Social {
  id       String  @id @default(uuid())
  github   String?
  linkedin String?
  twitter  String?
  reddit   String?
  dribbble String?
  website  String?

  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Posts {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  category    Category
  subCategory String?
  
  title       String
  description String
  slug        String   @unique
  image       String?
  platformUrl String?
  content     String
  published_at DateTime?

  likes_count Int        @default(0)
  views_count Int        @default(0)
  comments    Comments[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  likes      Likes[]
}

model Comments {
  id String @id @default(uuid())

  content String

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  post_id String
  post    Posts  @relation(fields: [post_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Likes {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  post_id String
  post    Posts  @relation(fields: [post_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model OtpRequest {
  id         String   @id @default(uuid())
  email      String   @unique
  otp        String
  first_name String
  last_name  String?
  username   String
  password   String
  expires_at DateTime
  created_at DateTime @default(now())
}

model ArticleView {
  id         String   @id @default(uuid())
  slug       String
  viewerHash String
  created_at DateTime @default(now())

  @@index([slug, viewerHash])
}
